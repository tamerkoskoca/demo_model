<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="test">

    <atmosphere type="adiabatic"/>
    <magnetic_field>6.0e-06 2.3e-05 -4.2e-05</magnetic_field>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>41.100799</latitude_deg>
      <longitude_deg>28.551562</longitude_deg>
      <elevation>488.0</elevation>
      <heading_deg>0</heading_deg>
    </spherical_coordinates>

    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-air-pressure-system"
            name="gz::sim::systems::AirPressure"/>
    <plugin filename="gz-sim-navsat-system"
            name="gz::sim::systems::NavSat"/>
    <plugin filename="gz-sim-magnetometer-system"
            name="gz::sim::systems::Magnetometer"/>
    <plugin filename="gz-sim-air-speed-system"
            name="gz::sim::systems::AirSpeed"/>

    <!-- Fizik motoru -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Gerekli eklentiler (Gazebo Sim 8 zorunlu) -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>

    <!-- Işık -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Zemin -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>500 500</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>500 500</size></plane></geometry>
          <material>
            <ambient>0.2 0.5 0.1 1</ambient>
            <diffuse>0.2 0.5 0.1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

   
    <!--   KALKIŞ/İNİŞ PİSTİ  -->
    
    <!-- Pist gövdesi: 100m x 10m, merkez orijinde -->
    <model name="runway_base">
      <static>true</static>
      <pose>0 0 0.01 0 0 0</pose>
      <link name="link">
        <visual name="asphalt">
          <geometry>
            <box><size>100 10 0.01</size></box>
          </geometry>
          <material>
            <ambient>0.15 0.15 0.15 1</ambient>
            <diffuse>0.15 0.15 0.15 1</diffuse>
          </material>
        </visual>
        <collision name="col">
          <geometry><box><size>100 10 0.01</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- Merkez çizgisi (beyaz, kesik kesik için 4 parça) -->
    <!-- Aralarına 10m boşluk, her parça 15*0,5m -->
    <model name="cl_0"><static>true</static><pose>-37.5 0 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>15 0.5 0.02</size></box></geometry>
        <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material>
      </visual></link></model>
    
    <model name="cl_1"><static>true</static><pose>-12.5 0 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>15 0.5 0.02</size></box></geometry>
        <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material>
      </visual></link></model>
    
    <model name="cl_2"><static>true</static><pose>12.5 0 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>15 0.5 0.02</size></box></geometry>
        <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material>
      </visual></link></model>
    
    <model name="cl_3"><static>true</static><pose>37.5 0 0.01 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>15 0.5 0.02</size></box></geometry>
        <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material>
      </visual></link></model>

