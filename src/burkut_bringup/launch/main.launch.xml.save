<?xml version="1.0" ?>
<launch>

    <!--Parametreler-->

    <arg name="world" default="test"/>
    <arg name="plane" default="advanced_plane"/>
    <arg name="airframe_id" default="4008"/>
    <arg name="instance" default="0"/>

    <!--Spawn -->

    <arg name="x" default="-45.0"/>
    <arg name="y" default="0"/>
    <arg name="z" default="0.5"/>
    <arg name="roll" default="0"/>
    <arg name="pitch" default="0"/>
    <arg name="yaw" default="0"/>
    <arg name="headless" default="false"/>

  <!-- ===== GZ_SIM_RESOURCE_PATH ===== -->
  <append_env name="GZ_SIM_RESOURCE_PATH"
              value="$(find-pkg-share burkut_worlds)/worlds"/>
  <append_env name="GZ_SIM_RESOURCE_PATH"
              value="$(find-pkg-share burkut_description)/models"/>

  <!-- ===== 1. Gazebo Harmonic ===== -->
  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args"
         value="-r $(find-pkg-share burkut_worlds)/worlds/$(var world).sdf"/>
  </include>

  <!-- ===== 2. Advanced Plane spawn ===== -->
  <node pkg="ros_gz_sim"
        exec="create"
        name="spawn_advanced_plane"
        output="screen"
        args="-name $(var plane)
              -x $(var x) -y $(var y) -z $(var z)
              -R $(var roll) -P $(var pitch) -Y $(var yaw)
              -file $(find-pkg-share burkut_description)/models/advanced_plane/model.sdf">
  </node>

  <!-- ===== 3. Clock Bridge ===== -->
  <node pkg="ros_gz_bridge"
        exec="parameter_bridge"
        name="bridge_clock"
        output="screen"
        args="/clock@rosgraph_msgs/msg/Clock[gz.msgs.Clock">
  </node>
<!-- ROS2 <=> Gazebo Bridge -->
  <node pkg="ros_gz_bridge"
        exec="parameter_bridge"
        name="bridge_camera"
        output="screen"
        args="/camera/image_raw@sensor_msgs/msg/Image[gz.msgs.Image
              /camera/camera_info@sensor_msgs/msg/CameraInfo[gz.msgs.CameraInfo">
  </node>


  <node pkg="ros_gz_bridge"
        exec="parameter_bridge"
        name="args="/world/test/model/advanced_plane/link/link/sensor/lidar_2d_v2/scan@sensor_msgs/msg/LaserScan[gz.msgs.LaserScan">bridge_lidar"
        output="screen"
        args="/lidar/scan@sensor_msgs/msg/LaserScan[gz.msgs.LaserScan">
  </node>

<node pkg="ros_gz_bridge" exec="parameter_bridge" name="bridge_tf" output="screen"
            args="/models/lidar_2d/pose@tf2_msgs/msg/TFMessage[gz.msgs.Pose_V">
        <remap from="/models/lidar_2d/pose" to="/tf"/>
    </node>

    <!-- Tf bağıntıları -->
    <node pkg="tf2_ros" exec="static_transform_publisher" name="tf_lidar"       
      args="0.18 0 0.04 0 0 0 base_link lidar_2d_link --ros-args -p use_sim_time:=true"
      output="screen">
    </node>

    <!-- base_link lidar_2d static tf bağlantısı-->
    <node pkg="tf2_ros" exec="static_transform_publisher" name="tf_base_to_model"
      args="0 0 0 0 0 0 base_link lidar_2d --ros-args -p use_sim_time:=true"
      output="screen">
    </node>
</launch>
